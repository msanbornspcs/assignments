%% banner_adder — System Process Flow (Mermaid; renders on GitHub / in the .md brief)
flowchart TD
    A["Operator enters a retailer URL<br/>(React UI &rarr; FastAPI server.py, mode=llm)"]:::input

    subgraph CAP["CAPTURE"]
        B["STEALTH CAPTURE<br/>anti-bot browser (patchright Chrome / camoufox Firefox)<br/>dismiss consent + modals (incl. shadow-DOM) &middot; human-shaped scroll<br/>&rarr; full-page screenshot"]:::cap
        Bd{"Blocked?"}:::dec
        Bx["Flag BLOCKED in UI<br/>(blocked &ne; 'no ads')<br/>retry other engine"]:::warn
    end

    subgraph PRE["PREFILTER"]
        C["DOM PREFILTER (dom_ads.py --generic)<br/>nominate candidate regions — makes NO ad decision<br/>expand carousels &middot; split mixed containers"]:::pre
        D["Crop every candidate region"]:::pre
        Dd{"Auto-skip?<br/>blank / chrome / clipped / junk"}:::dec
        Dx["SKIP — no model spent<br/>learned rules + reject-memory (keep-guarded)<br/>'LLM cycles saved' counter"]:::muted
    end

    E["Enqueue review job &rarr; file-based MCP queue<br/>runs/queue/&lt;id&gt;.json"]:::queue

    subgraph AGT["AGENT — autonomous /loop: poll &rarr; claim &rarr; review &rarr; submit &rarr; finish (+ heartbeat)"]
        F["REVIEWER AGENT claims job<br/>(claim_review over MCP stdio)"]:::agent
        G["Read each crop full-resolution &rarr; judge vs FIXED RUBRIC<br/>(brand is the anchor) &rarr; extract brand/price/savings/event"]:::agent
        Gd{"Names a<br/>specific brand?"}:::dec
        Gx["NOT an ad &rarr; is_ad=false<br/>category nav &middot; house/holiday<br/>financing &middot; multi-brand row"]:::muted
        H["submit_review — ONE verdict at a time (carry idx)<br/>&rarr; finish job &middot; verdicts stream live"]:::agent
    end

    subgraph OUT["OUTPUT & FEEDBACK"]
        I["UI renders ad cards + reject tray"]:::out
        J["Operator thumbs up/down &rarr; golden set + reject-memory<br/>+ feedback_learn (full-text keep-guard)"]:::out
        K["Export &rarr; ACME CSV schema (acme_export.py)"]:::out
        L["EVAL GATE — eval_detect.py vs INDEPENDENT ground truth<br/>IoU match &middot; PASS: recall &ge; 0.70 AND field-acc &ge; 0.70"]:::out
    end

    A --> B --> Bd
    Bd -- "yes" --> Bx
    Bd -- "no" --> C --> D --> Dd
    Dd -- "yes" --> Dx
    Dd -- "keep" --> E --> F --> G --> Gd
    Gd -- "no" --> Gx
    Gd -- "yes" --> H --> I --> J --> K
    K -. "governance check" .-> L
    J -. "feedback loop (learned junk rules + reject-memory, keep-guarded)" .-> Dd

    classDef input fill:#e8eaf6,stroke:#6366f1,color:#1a1a1a;
    classDef cap fill:#e8f5e9,stroke:#43a047,color:#1a1a1a;
    classDef pre fill:#fff8e1,stroke:#f9a825,color:#1a1a1a;
    classDef queue fill:#fde7f3,stroke:#d81b60,color:#1a1a1a;
    classDef agent fill:#e3f2fd,stroke:#1e88e5,color:#1a1a1a;
    classDef out fill:#f3e5f5,stroke:#8e24aa,color:#1a1a1a;
    classDef dec fill:#fffde7,stroke:#f9a825,color:#1a1a1a;
    classDef warn fill:#ffebee,stroke:#e53935,color:#1a1a1a;
    classDef muted fill:#f5f5f5,stroke:#9e9e9e,color:#1a1a1a;
